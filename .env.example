# LLM
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.2
OPENAI_MODEL_REPORT=gpt-5.2

# Optional: Better company lookup quality
SERPAPI_KEY=

# Optional: Debug logs for question flow
DEBUG_QUESTION_FLOW=0

# Optional: App port for local/dev runs
PORT=8000
# Optional: Host port published by docker-compose
HOST_PORT=8000

# Database backend (recommended for server deployment)
DB_BACKEND=mongodb
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_DB_NAME=ai_enable_discovery

# Report storage backend (Backblaze B2 S3-compatible)
REPORT_STORAGE_BACKEND=s3
S3_ENDPOINT_URL=https://s3.<region>.backblazeb2.com
S3_REGION=us-east-005
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY_ID=your-key-id
S3_SECRET_ACCESS_KEY=your-secret-key
REPORTS_PREFIX=reports
S3_PUBLIC_BASE_URL=

# Disable local reports in container/VM for stateless runtime
DISABLE_LOCAL_REPORTS=1

# Local-only fallbacks (used only if you switch to sqlite/local storage)
SQLITE_DB_PATH=data/sessions.db
LOCAL_REPORTS_DIR=reports
